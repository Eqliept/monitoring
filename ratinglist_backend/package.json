{
  "scripts": {
    "typeorm": "ts-node node_modules/typeorm/cli.js",
    "db:generate": "npm run typeorm -- migration:generate -d database/data-source.ts ./database/migrations/auto",
    "db:run": "npm run typeorm -- migration:run -d database/data-source.ts",
    "db:run:prod": "typeorm migration:run -d dist/database/data-source.js",
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev server.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "mcproto": "^0.9.0",
    "pg": "^8.20.0",
    "pgvector": "^0.3.0",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.29",
    "unique-username-generator": "^1.5.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.8.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3"
  }
}
